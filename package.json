{
  "name": "collabice-web-client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "doppler run -- next dev",
    "dev:qw": "NODE_PATH=. doppler run -- ts-node -O '{\"module\":\"commonjs\"}' functions/src/queue-workers.ts",
    "build": "node scripts/create-env.js && next build",
    "build-functions": "node scripts/create-env.js && rm -rf build/ && NODE_OPTIONS=\"--max-old-space-size=8192\" webpack --config webpack.qw.config.js",
    "dev:build": "doppler run -- next build",
    "start": "node --require dd-trace/init node_modules/.bin/next start",
    "start:qw": "node -r dotenv/config -r dd-trace/init build/queue-workers.ts/index.js",
    "flow": "flow",
    "test": "jest",
    "test-dev": "doppler run -- jest",
    "prepare": "husky install",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@ant-design/icons": "^4.2.2",
    "@aws-sdk/client-dynamodb": "^3.256.0",
    "@aws-sdk/client-dynamodb-streams": "^3.53.0",
    "@aws-sdk/client-secrets-manager": "^3.53.0",
    "@types/multiparty": "^0.0.33",
    "@types/object-hash": "^3.0.2",
    "@types/uuid": "^9.0.0",
    "amazon-dax-client": "^1.2.8",
    "antd": "^4.6.6",
    "archiver": "^5.3.1",
    "async": "^3.2.2",
    "aws-sdk": "^2.814.0",
    "axios": "^0.21.2",
    "axios-retry": "^3.2.4",
    "class-transformer": "^0.5.1",
    "cors": "^2.8.5",
    "dd-trace": "^1.5.0",
    "dotenv": "^16.0.1",
    "dynamoose": "^3.1.0",
    "firebase": "^9.6.6",
    "firebase-admin": "^9.9.0",
    "form-data": "^4.0.0",
    "heic-convert": "^1.2.4",
    "immutable": "^4.0.0-rc.12",
    "invariant": "^2.2.4",
    "inversify": "^6.0.1",
    "joi": "^17.4.0",
    "jsonwebtoken": "^8.5.1",
    "lodash": "^4.17.21",
    "luxon": "^1.25.0",
    "memorystream": "^0.3.1",
    "multiparty": "^4.2.3",
    "nanoid": "^3.1.31",
    "next": "12.2.2",
    "nextjs-redirect": "^5.0.2",
    "node-cache": "^5.1.2",
    "node-random-name": "^1.0.1",
    "object-hash": "^3.0.0",
    "qs": "^6.10.5",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "referral-code-generator": "^1.0.8",
    "reflect-metadata": "^0.1.13",
    "sharp": "^0.30.5",
    "sqs-consumer": "^5.6.0",
    "tiny-invariant": "^1.1.0",
    "ts-node": "^10.5.0",
    "uuid": "^9.0.0",
    "winston": "^3.6.0",
    "xstate": "^4.29.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.16.1",
    "@testing-library/react": "^12.1.2",
    "@types/amazon-dax-client": "^1.2.3",
    "@types/archiver": "^5.3.1",
    "@types/cors": "^2.8.12",
    "@types/joi": "^17.2.3",
    "@types/jsonwebtoken": "^8.5.9",
    "@types/lodash": "^4.14.172",
    "@types/luxon": "^1.26.5",
    "@types/memorystream": "^0.3.0",
    "@types/node": "^14.14.34",
    "@types/qs": "^6.9.7",
    "@types/react": "^17.0.3",
    "@types/sharp": "^0.28.5",
    "@typescript-eslint/eslint-plugin": "^5.13.0",
    "@typescript-eslint/parser": "^5.13.0",
    "babel-plugin-dev-expression": "^0.2.2",
    "babel-plugin-transform-flow-strip-types": "^6.22.0",
    "eslint": "^8.10.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-import-resolver-typescript": "^2.5.0",
    "eslint-plugin-import": "^2.25.4",
    "flow-bin": "^0.135.0",
    "glob": "^7.2.0",
    "husky": "^7.0.4",
    "jest": "^27.4.5",
    "jest-mock": "^29.2.1",
    "lint-staged": "^12.3.4",
    "patch-package": "^6.4.7",
    "prettier": "^2.5.1",
    "ts-loader": "^9.2.6",
    "typescript": "^4.4.3",
    "webpack": "^5.68.0",
    "webpack-cli": "^4.9.2",
    "webpack-glob": "^2.0.2",
    "webpack-node-externals": "^3.0.0"
  },
  "lint-staged": {
    "*.{js,ts,json}": "prettier --check",
    "*.{js,ts}": "eslint --cache"
  }
